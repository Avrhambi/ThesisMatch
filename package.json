{
  "name": "research-finder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "node --env-file=.env scripts/migrate.mjs",
    "db:reset": "node --env-file=.env scripts/reset-db.mjs",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@google/genai": "2.12.0",
    "cheerio": "1.2.0",
    "next": "16.2.10",
    "pdf-parse": "2.4.5",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "20.19.32",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.20",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "vitest": "3.2.7"
  }
}
